# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE=your-service-role

# Hugging Face Inference API
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxx

# Blockchain Trust Registry
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGONSCAN_API_KEY=your-api-key
PRIVATE_KEY=your-deployer-private-key
NEXT_PUBLIC_REGISTRY_ADDRESS=0x00000000000000000000

# Telemetry
OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
GRAFANA_INSTANCE_ID=your-instance-id
GRAFANA_API_KEY=your-grafana-key

# Queues
REDIS_URL=rediss://default:pwd@upstash.io:6379
